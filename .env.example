# Variables de entorno de referencia � copiar a .env (no commitear .env)

# Version de JARs para docker compose perfil apps
REV_VERSION=1.0-SNAPSHOT

# PostgreSQL - ms-incidentes
POSTGRES_INCIDENTES_HOST=localhost
POSTGRES_INCIDENTES_PORT=5432
POSTGRES_INCIDENTES_DB=rev_incidentes
POSTGRES_INCIDENTES_USER=rev
POSTGRES_INCIDENTES_PASSWORD=rev123

# PostgreSQL + PostGIS - ms-zonas-riesgo
POSTGRES_ZONAS_HOST=localhost
POSTGRES_ZONAS_PORT=5433
POSTGRES_ZONAS_DB=rev_zonas
POSTGRES_ZONAS_USER=rev
POSTGRES_ZONAS_PASSWORD=rev123

# PostgreSQL - ms-recursos
POSTGRES_RECURSOS_HOST=localhost
POSTGRES_RECURSOS_PORT=5434
POSTGRES_RECURSOS_DB=rev_recursos
POSTGRES_RECURSOS_USER=rev
POSTGRES_RECURSOS_PASSWORD=rev123

# Keycloak
KEYCLOAK_URL=http://localhost:8090
KEYCLOAK_REALM=rev
KEYCLOAK_CLIENT_ID=rev-frontend
KEYCLOAK_CLIENT_SECRET=rev-dev-secret

# Eureka
EUREKA_URL=http://localhost:8761/eureka/
