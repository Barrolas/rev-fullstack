# Variables de entorno de referencia — copiar a .env (no commitear .env)
#
# Puertos REV en rango 15xxx/18xxx para no chocar con Rakin IA (8070, 8084, 5432).
# Dentro de Docker los contenedores siguen en 8080/8081/…; solo cambia el mapeo al host.

REV_VERSION=1.0-SNAPSHOT

# Frontend (Vite)
REV_FRONTEND_PORT=15173
VITE_REV_GATEWAY_PORT=18080
VITE_KEYCLOAK_URL=http://localhost:18090

# Infra expuesta al host
REV_GATEWAY_PORT=18080
REV_EUREKA_PORT=18761
REV_KEYCLOAK_PORT=18090
REV_SBA_PORT=18099

# Microservicios expuestos al host (Maven local usa estos mismos valores)
REV_MS_INCIDENTES_PORT=18081
REV_MS_ZONAS_PORT=18082
REV_MS_RECURSOS_PORT=18083
REV_BFF_PORT=18085
REV_KEYCLOAK_ADAPTER_PORT=18088

# PostgreSQL — host (Rakin IA usa 5432)
REV_PG_INCIDENTES_PORT=15432
REV_PG_ZONAS_PORT=15433
REV_PG_RECURSOS_PORT=15434

POSTGRES_INCIDENTES_HOST=localhost
POSTGRES_INCIDENTES_PORT=15432
POSTGRES_INCIDENTES_DB=rev_incidentes
POSTGRES_INCIDENTES_USER=rev
POSTGRES_INCIDENTES_PASSWORD=rev123

POSTGRES_ZONAS_HOST=localhost
POSTGRES_ZONAS_PORT=15433
POSTGRES_ZONAS_DB=rev_zonas
POSTGRES_ZONAS_USER=rev
POSTGRES_ZONAS_PASSWORD=rev123

POSTGRES_RECURSOS_HOST=localhost
POSTGRES_RECURSOS_PORT=15434
POSTGRES_RECURSOS_DB=rev_recursos
POSTGRES_RECURSOS_USER=rev
POSTGRES_RECURSOS_PASSWORD=rev123

KEYCLOAK_URL=http://localhost:18090
KEYCLOAK_REALM=rev
KEYCLOAK_CLIENT_ID=rev-frontend
KEYCLOAK_CLIENT_SECRET=rev-dev-secret

EUREKA_URL=http://localhost:18761/eureka/
